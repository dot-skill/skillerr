{
  "name": "skillerr-monorepo",
  "version": "0.9.0",
  "private": true,
  "description": "Easily create, inspect, and run portable .skill packages for AI agents",
  "license": "MIT",
  "author": {
    "name": "Bharat Dudeja",
    "url": "https://github.com/bharatdudeja13-cmd"
  },
  "keywords": [
    "skill",
    "skillerr",
    ".skill",
    "ai-agents",
    "agent-skills",
    "protocol",
    "portable",
    "inspectable"
  ],
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @skillerr/protocol && npm run build -w @skillerr/core && npm run build -w @skillerr/runtime && npm run build -w @skillerr/registry && npm run build -w @skillerr/workspace && npm run build -w @skillerr/cli",
    "test": "npm run build && npm test --workspaces --if-present",
    "test:examples": "node scripts/test-examples.mjs",
    "pack:check": "npm pack --workspaces --dry-run",
    "pack:check:meta": "npm pack -w skillerr --dry-run",
    "skill": "node packages/cli/dist/cli.js",
    "skillerr": "node packages/cli/dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "png-to-ico": "^3.0.2",
    "sharp": "^0.35.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dot-skill/skillerr.git"
  },
  "homepage": "https://dot-skill.github.io/skillerr-com/",
  "bugs": {
    "url": "https://github.com/dot-skill/skillerr/issues"
  }
}
