{
  "name": "@skillerr/protocol",
  "version": "1.2.0",
  "description": "Types, schemas, and completeness rules for portable .skill packages",
  "license": "MIT",
  "author": {
    "name": "Bharat Dudeja",
    "url": "https://github.com/bharatdudeja13-cmd"
  },
  "keywords": [
    "skill",
    ".skill",
    "ai-agents",
    "agent-skills",
    "protocol",
    "types"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dot-skill/skillerr.git",
    "directory": "packages/protocol"
  },
  "homepage": "https://www.skillerr.com/docs/",
  "bugs": {
    "url": "https://github.com/dot-skill/skillerr/issues"
  },
  "files": [
    "dist",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
    "skill-contract.schema.json",
    "skill-manifest.schema.json",
    "workflow.schema.json",
    "knowledge-item.schema.json",
    "creation-attestation.schema.json",
    "skill-anchor-statement.schema.json",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./skill-contract.schema.json": "./skill-contract.schema.json",
    "./skill-manifest.schema.json": "./skill-manifest.schema.json",
    "./workflow.schema.json": "./workflow.schema.json",
    "./knowledge-item.schema.json": "./knowledge-item.schema.json",
    "./creation-attestation.schema.json": "./creation-attestation.schema.json",
    "./skill-anchor-statement.schema.json": "./skill-anchor-statement.schema.json"
  },
  "scripts": {
    "build": "rimraf dist && tsc",
    "prepack": "npm run build",
    "clean": "rimraf dist",
    "test": "node --test dist/protocol.test.js"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^5.4.5"
  }
}
