{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skillerr.com/schema/0.5/skill-manifest.schema.json",
  "title": "Open .skill 0.5 package manifest (skill.json)",
  "type": "object",
  "required": [
    "kind",
    "id",
    "version",
    "title",
    "description",
    "container_version",
    "protocol_version",
    "entrypoint",
    "inputs",
    "outputs",
    "capabilities",
    "permissions",
    "policy",
    "content",
    "package_digest",
    "provenance_mode"
  ],
  "properties": {
    "kind": { "const": "dot-skill" },
    "id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "intent": { "type": "string" },
    "contract": { "$ref": "./skill-contract.schema.json" },
    "authors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "display_name": { "type": "string" }
        }
      }
    },
    "license": { "type": "string" },
    "license_url": { "type": "string" },
    "container_version": { "type": "string" },
    "protocol_version": { "type": "string" },
    "entrypoint": { "type": "string", "minLength": 1 },
    "inputs": { "type": "array", "items": { "$ref": "#/$defs/inputSlot" } },
    "outputs": { "type": "array", "items": { "$ref": "#/$defs/outputContract" } },
    "capabilities": { "type": "array", "items": { "$ref": "#/$defs/capabilityRequirement" } },
    "permissions": { "type": "array", "items": { "$ref": "#/$defs/skillPermission" } },
    "policy": { "$ref": "#/$defs/skillPolicy" },
    "content": { "type": "array", "items": { "$ref": "#/$defs/contentDigest" } },
    "package_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "manifest_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["skill_id", "version"],
        "properties": {
          "skill_id": { "type": "string" },
          "version": { "type": "string" },
          "package_digest": { "type": "string" }
        }
      }
    },
    "supersedes": { "type": "string" },
    "provenance_mode": { "enum": ["full", "redacted", "proof_only"] },
    "compile_profile": { "enum": ["continuity", "release"] },
    "completeness": {
      "type": "object",
      "required": ["kind", "profile", "complete", "present", "missing", "hints"],
      "properties": {
        "kind": { "const": "completeness_report" },
        "profile": { "enum": ["continuity", "release"] },
        "complete": { "type": "boolean" },
        "present": { "type": "array", "items": { "type": "string" } },
        "missing": { "type": "array", "items": { "type": "string" } },
        "hints": { "type": "array", "items": { "type": "string" } }
      }
    },
    "package_sensitivity": { "enum": ["private", "shareable_redacted", "public"] },
    "mint": {
      "type": "object",
      "required": ["mint_status"],
      "properties": {
        "mint_status": { "enum": ["draft", "minted"] },
        "minted_at": { "type": "string" },
        "mint_issuer": { "type": "string" },
        "content_id": { "type": "string" }
      }
    },
    "attestation_digest": { "type": "string" },
    "sealed_manifest_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "anchors": { "type": "array", "items": { "type": "object" } },
    "legacy": { "type": "boolean" },
    "needs_human_review": { "type": "boolean" },
    "extensions": { "type": "object" }
  },
  "$defs": {
    "inputSlot": {
      "type": "object",
      "required": ["name", "schema", "description", "source", "required", "sensitivity", "ask_when"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "schema": { "type": "object" },
        "description": { "type": "string" },
        "source": { "enum": ["human", "environment", "secret", "artifact", "derived"] },
        "required": { "type": "boolean" },
        "sensitivity": { "enum": ["public", "private", "secret"] },
        "ask_when": { "enum": ["always", "if_missing", "never"] },
        "approval": { "enum": ["none", "human_before_use"] },
        "approved": { "type": "boolean" }
      }
    },
    "outputContract": {
      "type": "object",
      "required": ["name", "schema", "required"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "schema": { "type": "object" },
        "required": { "type": "boolean" },
        "media_type": { "type": "string" },
        "assert": { "type": "array", "items": { "type": "string" } }
      }
    },
    "capabilityRequirement": {
      "type": "object",
      "required": ["name", "description", "side_effect_class", "fallback", "required"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "side_effect_class": { "$ref": "#/$defs/sideEffectClass" },
        "fallback": { "enum": ["fail", "ask_human", "skip_if_optional"] },
        "required": { "type": "boolean" }
      }
    },
    "skillPermission": {
      "type": "object",
      "required": ["side_effect_class", "description", "requires_consent"],
      "properties": {
        "side_effect_class": { "$ref": "#/$defs/sideEffectClass" },
        "description": { "type": "string" },
        "paths": { "type": "array", "items": { "type": "string" } },
        "hosts": { "type": "array", "items": { "type": "string" } },
        "requires_consent": { "type": "boolean" }
      }
    },
    "skillPolicy": {
      "type": "object",
      "required": [
        "require_signatures",
        "max_runtime_ms",
        "max_tool_calls",
        "allow_network",
        "consent_for",
        "fail_on_unsupported_step"
      ],
      "properties": {
        "require_signatures": { "type": "boolean" },
        "require_minted": { "type": "boolean" },
        "require_anchor": { "type": "boolean" },
        "max_runtime_ms": { "type": "integer", "minimum": 0 },
        "max_tool_calls": { "type": "integer", "minimum": 0 },
        "allow_network": { "type": "boolean" },
        "filesystem_roots": { "type": "array", "items": { "type": "string" } },
        "consent_for": { "type": "array", "items": { "$ref": "#/$defs/sideEffectClass" } },
        "fail_on_unsupported_step": { "type": "boolean" },
        "trust_profile": { "type": "string" }
      }
    },
    "contentDigest": {
      "type": "object",
      "required": ["path", "digest"],
      "properties": {
        "path": { "type": "string" },
        "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "media_type": { "type": "string" },
        "bytes": { "type": "integer", "minimum": 0 }
      }
    },
    "sideEffectClass": { "enum": ["none", "read", "write", "network", "exec", "destructive"] }
  }
}
