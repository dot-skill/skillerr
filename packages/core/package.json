{
  "name": "@skillerr/core",
  "version": "1.5.1",
  "description": "Compile, pack, validate, and mint portable .skill packages",
  "license": "MIT",
  "author": {
    "name": "Bharat Dudeja",
    "url": "https://github.com/bharatdudeja13-cmd"
  },
  "keywords": [
    "skill",
    ".skill",
    "ai-agents",
    "agent-skills",
    "compile",
    "mint"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dot-skill/skillerr.git",
    "directory": "packages/core"
  },
  "homepage": "https://www.skillerr.com/docs/",
  "bugs": {
    "url": "https://github.com/dot-skill/skillerr/issues"
  },
  "files": [
    "dist",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "rimraf dist && tsc",
    "prepack": "npm run build",
    "clean": "rimraf dist",
    "test": "node --test dist/core.test.js dist/ingest.test.js dist/eval.test.js dist/transparency.test.js dist/claims.test.js dist/default-issuer.test.js"
  },
  "dependencies": {
    "@sigstore/bundle": "^5.0.0",
    "@sigstore/core": "^4.0.1",
    "@sigstore/sign": "^5.0.0",
    "@sigstore/tuf": "^4.0.2",
    "@sigstore/verify": "^4.1.0",
    "@skillerr/protocol": "^1.5.1",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.4.5"
  }
}
