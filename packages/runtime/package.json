{
  "name": "@skillerr/runtime",
  "version": "0.8.0",
  "description": "Inspect, dry-run, and execute portable .skill packages",
  "license": "MIT",
  "author": {
    "name": "Bharat Dudeja",
    "url": "https://github.com/bharatdudeja13-cmd"
  },
  "keywords": [
    "skill",
    ".skill",
    "ai-agents",
    "agent-skills",
    "runtime",
    "dry-run"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dot-skill/skillerr.git",
    "directory": "packages/runtime"
  },
  "homepage": "https://dot-skill.github.io/skillerr-com/",
  "bugs": {
    "url": "https://github.com/dot-skill/skillerr/issues"
  },
  "files": [
    "dist",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "rimraf dist && tsc",
    "prepack": "npm run build",
    "clean": "rimraf dist",
    "test": "node --test dist/runtime.test.js"
  },
  "dependencies": {
    "@skillerr/core": "^0.8.0",
    "@skillerr/protocol": "^0.8.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.4.5"
  }
}
