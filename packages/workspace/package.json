{
  "name": "@skillerr/workspace",
  "version": "1.0.0",
  "description": "Local workspace for sections, stage, compile, checkpoint, and mint",
  "license": "MIT",
  "author": {
    "name": "Bharat Dudeja",
    "url": "https://github.com/bharatdudeja13-cmd"
  },
  "keywords": [
    "skill",
    ".skill",
    "ai-agents",
    "agent-skills",
    "workspace",
    "continuity"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dot-skill/skillerr.git",
    "directory": "packages/workspace"
  },
  "homepage": "https://www.skillerr.com/docs/",
  "bugs": {
    "url": "https://github.com/dot-skill/skillerr/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "prepack": "npm run build",
    "test": "node --test dist/workspace.test.js"
  },
  "dependencies": {
    "@skillerr/core": "^1.0.0",
    "@skillerr/protocol": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3"
  }
}
