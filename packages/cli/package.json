{
  "name": "@skillerr/cli",
  "version": "0.9.8",
  "description": "CLI implementation for portable .skill packages (install skillerr for the skill bin)",
  "license": "MIT",
  "author": {
    "name": "Bharat Dudeja",
    "url": "https://github.com/bharatdudeja13-cmd"
  },
  "keywords": [
    "skill",
    "skillerr",
    ".skill",
    "ai-agents",
    "agent-skills",
    "cli",
    "protocol"
  ],
  "type": "module",
  "bin": {
    "skill": "./dist/cli.js",
    "skillerr": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dot-skill/skillerr.git",
    "directory": "packages/cli"
  },
  "homepage": "https://www.skillerr.com/docs/",
  "bugs": {
    "url": "https://github.com/dot-skill/skillerr/issues"
  },
  "files": [
    "dist/cli.js",
    "dist/cli.d.ts",
    "dist/score-adapter.js",
    "dist/score-adapter.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "prepack": "npm run build",
    "test": "node --test dist/conformance.test.js dist/adversarial.test.js dist/score-adapter.test.js"
  },
  "dependencies": {
    "@skillerr/core": "^0.9.8",
